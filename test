plot_lm <- function(data, y_var, y_label) {
  
  y_quo  <- rlang::enquo(y_var)
  y_name <- rlang::as_name(y_quo)
  
  # 建立模型
  formula <- as.formula(paste0("Yw ~ `", y_name, "`"))
  model <- lm(formula, data = data)
  
  # 提取统计量
  r2 <- summary(model)$r.squared
  p  <- summary(model)$coefficients[2, 4]
  intercept <- coef(model)[1]
  slope <- coef(model)[2]
  
  # 构造标签
  p_label <- ifelse(p < 0.01, "p < 0.01", "p > 0.01")
  
  label <- paste0(
    #"y = ", round(slope, 2), "x + ", round(intercept, 1),
    "\nR² = ", round(r2, 2),
    "\n", p_label
  )
  

  # 绘图
  p_plot <- ggplot(data, aes(x =Yw , y = .data[[y_name]])) +
    geom_point(size = 3, alpha = 0.6) +
    geom_smooth(method = "lm",
                color = "red",
                se = TRUE) +
    annotate("text",
             #x = max(data$Yw, na.rm = TRUE),
             #y = max(data[[y_name]], na.rm = TRUE),
             x = Inf,
             y = Inf,
             label = label,
             hjust = 1.2, vjust =0.8,
             size = 7) +
    theme_bw() +
    labs(x ="Yield potential (kg/ha)" ,
         y = y_label)+
    theme(
      axis.title.x = element_text(size = 16),
      axis.title.y = element_text(size = 16),
      axis.text.x = element_text(size = 14),
      axis.text.y = element_text(size = 14)
    )
  
  return(p_plot)
}

