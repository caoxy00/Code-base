plot_box_risk <- function(data, y_var, y_label) {
  
  color <- c(
    "Low" = "#c8605A",
    "Medium" = "#E7BF25",
    "High" = "#83A8D6"
  )
  
  data2 <- data %>%
    mutate(
      Classification = factor(`Cold stress region`,
                              levels = c("Low", "Medium", "High"))
    )
  
  y_quo  <- rlang::enquo(y_var)
  y_name <- rlang::as_name(y_quo)
  y_vals <- data2[[y_name]]
  
  y_max <- max(y_vals, na.rm = TRUE)
  y_min <- min(y_vals, na.rm = TRUE)
  y_range <- y_max - y_min
  if (y_range == 0) y_range <- abs(y_max) * 0.1 + 1
  
  p <- ggplot(data2, aes(x = Classification,
                         y = .data[[y_name]],
                         fill = Classification)) +
    geom_boxplot(alpha = 0.7) +
    geom_jitter(aes(color = Classification),
                width = 0.15,
                size = 5,
                alpha = 0.25,
                shape = 20,
                stroke = 0.5) +
    stat_summary(fun = mean,
                 geom = "crossbar",
                 width = 0.6,
                 linetype = "dashed",
                 color = "black",
                 linewidth = 0.5) +
    geom_signif(
      comparisons = list(
        c("Low", "Medium"),
        c("Low", "High"),
        c("Medium", "High")
      ),
      map_signif_level = TRUE,
      test = t.test,
      y_position = c(
        y_max + y_range * 0.08,
        y_max + y_range * 0.16,
        y_max + y_range * 0.24
      ),
      tip_length = c(0.02, 0.02),
      size = 0.8,
      color = "black",
      textsize = 5
    ) +
    labs(x = "Risk level",
         y = y_label) +
    theme_prism(
      palette = "candy_bright",
      base_fontface = "plain",
      base_family = "serif",
      base_size = 16,
      base_line_size = 0.8,
      axis_text_angle = 0
    ) +
    scale_fill_manual(values = color) +
    scale_color_manual(values = color) +
    theme(legend.position = "none")
  
  return(p)
}

